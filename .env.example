# Copie ce fichier en .env et remplis tes valeurs
# Ne commite JAMAIS le .env sur Git

OPENAI_API_KEY=sk-...

# Modèle à utiliser
OPENAI_MODEL=gpt-4o-mini

# Chemin vers la base ChromaDB (local)
CHROMA_DB_PATH=./data/chromadb

# Chemin SQLite
SQLITE_DB_PATH=./data/coach.db

# Dossier de stockage des PDFs importés
UPLOADS_PATH=./data/uploads

# Dossier des rapports exportés
REPORTS_PATH=./data/reports