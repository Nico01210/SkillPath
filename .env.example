# Copie ce fichier en .env et remplis tes valeurs
# Ne commite JAMAIS le .env sur Git

OPENAI_API_KEY=sk-...

# Modèle à utiliser
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# Les chemins (ChromaDB, SQLite, uploads, rapports) sont calculés
# automatiquement à partir de la racine du projet (voir backend/config.py).
# Ne les définis ici QUE si tu veux les stocker ailleurs, avec des
# chemins ABSOLUS (un chemin relatif dépendrait du dossier de lancement).
# CHROMA_DB_PATH=/chemin/absolu/vers/data/chromadb
# SQLITE_DB_PATH=/chemin/absolu/vers/data/coach.db
# UPLOADS_PATH=/chemin/absolu/vers/data/uploads
# REPORTS_PATH=/chemin/absolu/vers/data/reports
